# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# ========================================
# Core Application Settings
# ========================================

# Encryption key for mapping storage (generate with: python crypto_util.py)
ENCRYPTION_KEY=your-generated-key-here

# Flask environment (development or production)
FLASK_ENV=development

# Flask debug mode (true or false)
FLASK_DEBUG=false

# Port for the application (default: 5000)
PORT=5000

# ========================================
# LLM Integration (Groq)
# ========================================

# Groq API Key (get from https://console.groq.com/keys)
# Optional - if not set, LLM features will use mock mode
GROQ_API_KEY=your-groq-api-key-here

# Groq Model to use (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# ========================================
# Google Cloud Vision OCR Setup
# ========================================

# Option 1: Set GCP credentials as JSON string (recommended for Render)
# Get this from Google Cloud service account JSON file
# GCP_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Option 2: Set GCP credentials from file path
# GCP_CREDENTIALS_PATH=/path/to/service-account-key.json

# Option 3: Use Google Application Default Credentials (for GCP infrastructure)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Note: If none of the above are set, the app will fall back to local Tesseract OCR

# ========================================
# File Storage
# ========================================

# Path to encrypted mappings file
MAPPINGS_FILE=mappings.enc

# ========================================
# Render Specific (if deploying to Render)
# ========================================

# Set to production for Render
# FLASK_ENV=production
# FLASK_DEBUG=false
